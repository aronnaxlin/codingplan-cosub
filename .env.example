PORT=8787
ADMIN_TOKEN=change-this-admin-token
JWT_SECRET=change-me-secret
CODING_PLAN_API_KEY=sk-your-provider-key
CODING_PLAN_UPSTREAM_BASE_URL=https://provider.example/coding/v1
CODING_PLAN_USAGE_URL=https://provider.example/coding/v1/usages
GLOBAL_CONCURRENCY_LIMIT=2
DATA_FILE=./data/store.json
CODING_PLAN_QUOTA_USER_AGENT=CodingPlanProxy/0.1 quota-check
# Official quota checks are disabled by default in app settings because they make an extra upstream request with this UA.

# Defaults follow public coding-plan estimates.
# Andante:    5h 359 req / 15,000,000 tokens, 7d 639 req / 21,000,000 tokens
# Allegretto: 5h 1,307 req / 65,000,000 tokens, 7d 9,073 req / 357,000,000 tokens
