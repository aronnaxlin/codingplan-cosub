PORT=8787
ADMIN_TOKEN=change-this-admin-token
KIMI_API_KEY=sk-your-kimi-code-key
KIMI_UPSTREAM_BASE_URL=https://api.kimi.com/coding/v1
GLOBAL_CONCURRENCY_LIMIT=2
DATA_FILE=./data/store.json
KIMI_QUOTA_USER_AGENT=KimiThinProxy/0.1 quota-check
# Official quota checks are disabled by default in app settings because they make an extra upstream request with this UA.

# Defaults follow awesome-coding-plan's Kimi Code Allegretto estimates.
# Andante:    5h 359 req / 15,000,000 tokens, 7d 639 req / 21,000,000 tokens, 30d 2,556 req / 84,000,000 tokens
# Allegretto: 5h 1,307 req / 65,000,000 tokens, 7d 9,073 req / 357,000,000 tokens, 30d 36,292 req / 1,428,000,000 tokens
